# Salin file ini menjadi .env untuk development lokal.
# JANGAN commit file .env ke git.

# Port server (Railway akan otomatis mengisi PORT sendiri, tidak perlu diset manual di Railway)
PORT=3000

# Opsi 1: gunakan connection string langsung (biasanya disediakan otomatis oleh Railway MySQL plugin)
# DATABASE_URL=mysql://user:password@host:port/database_name

# Opsi 2: atau gunakan variable terpisah
DB_HOST=localhost
DB_PORT=3306
DB_NAME=teori15_db
DB_USER=root
DB_PASSWORD=

# URL frontend yang diizinkan mengakses backend (untuk CORS), pisahkan dengan koma jika lebih dari satu
FRONTEND_URL=http://localhost:5173
